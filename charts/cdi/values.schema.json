{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CDI Helm Chart Values",
  "description": "Configuration values for the Containerized Data Importer (CDI) Helm chart.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "title": "Global Configuration",
      "description": "Global settings shared across all subcharts. Additional properties are allowed because a parent umbrella chart may inject arbitrary global values that are consumed by other sub-charts and passed through Helm's global mechanism.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "imageRegistry": {
          "title": "Image Registry",
          "description": "Global container image registry override. When set, all images will be pulled from this registry.",
          "type": "string",
          "default": ""
        },
        "imagePullSecrets": {
          "title": "Image Pull Secrets",
          "description": "Global list of image pull secrets for authenticating to private registries.",
          "type": "array",
          "default": [],
          "items": {
            "type": "object"
          }
        },
        "nodeSelector": {
          "title": "Node Selector",
          "description": "Global node selector applied to all pods.",
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          }
        },
        "tolerations": {
          "title": "Tolerations",
          "description": "Global tolerations applied to all pods.",
          "type": "array",
          "default": [],
          "items": {
            "type": "object"
          }
        },
        "kubevirtNamespace": {
          "title": "KubeVirt Namespace",
          "description": "Global KubeVirt namespace. Used by subcharts that deploy into the KubeVirt namespace.",
          "type": "string",
          "default": "kubevirt"
        }
      }
    },
    "namespace": {
      "title": "Namespace",
      "description": "Kubernetes namespace where CDI components will be deployed.",
      "type": "string",
      "default": "cdi"
    },
    "version": {
      "title": "Version",
      "description": "CDI version to deploy.",
      "type": "string",
      "default": "v1.65.0"
    },
    "operator": {
      "title": "Operator Configuration",
      "description": "Configuration for the CDI operator deployment.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicas": {
          "title": "Replicas",
          "description": "Number of CDI operator pod replicas.",
          "type": "integer",
          "default": 1,
          "minimum": 0
        },
        "image": {
          "title": "Image",
          "description": "Container image settings for the CDI operator.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "title": "Repository",
              "description": "Container image repository for the CDI operator.",
              "type": "string",
              "default": "quay.io/kubevirt/cdi-operator"
            }
          }
        },
        "resources": {
          "title": "Resource Requirements",
          "description": "CPU and memory resource requests and limits.",
          "type": "object",
          "properties": {
            "requests": {
              "title": "Resource Requests",
              "description": "Minimum resources required for scheduling.",
              "type": "object",
              "properties": {
                "cpu": {
                  "title": "CPU Request",
                  "description": "CPU request (e.g. 100m, 1).",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "memory": {
                  "title": "Memory Request",
                  "description": "Memory request (e.g. 128Mi, 1Gi).",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    }
                  ]
                }
              }
            },
            "limits": {
              "title": "Resource Limits",
              "description": "Maximum resources the container can use.",
              "type": "object",
              "properties": {
                "cpu": {
                  "title": "CPU Limit",
                  "description": "CPU limit (e.g. 500m, 2).",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "memory": {
                  "title": "Memory Limit",
                  "description": "Memory limit (e.g. 512Mi, 2Gi).",
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    }
                  ]
                }
              }
            }
          }
        },
        "nodeSelector": {
          "title": "Node Selector",
          "description": "Node selector for scheduling the CDI operator pods.",
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          }
        },
        "tolerations": {
          "title": "Tolerations",
          "description": "Tolerations for the CDI operator pods.",
          "type": "array",
          "default": [],
          "items": {
            "type": "object"
          }
        }
      }
    },
    "cr": {
      "title": "Custom Resource Configuration",
      "description": "Configuration for the CDI custom resource instance.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config": {
          "title": "Config",
          "description": "CDI configuration settings applied to the CDI custom resource.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "featureGates": {
              "title": "Feature Gates",
              "description": "List of CDI feature gates to enable.",
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "podResourceRequirements": {
              "title": "Pod Resource Requirements",
              "description": "Resource requirements for CDI importer/cloner pods.",
              "type": "object",
              "properties": {
                "limits": {
                  "type": "object",
                  "properties": {
                    "cpu": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        }
                      ],
                      "title": "CPU Limit"
                    },
                    "memory": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        }
                      ],
                      "title": "Memory Limit"
                    }
                  }
                },
                "requests": {
                  "type": "object",
                  "properties": {
                    "cpu": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        }
                      ],
                      "title": "CPU Request"
                    },
                    "memory": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        }
                      ],
                      "title": "Memory Request"
                    }
                  }
                }
              }
            }
          }
        },
        "imagePullPolicy": {
          "title": "Image Pull Policy",
          "description": "Image pull policy for CDI workload pods managed by the operator.",
          "type": "string",
          "default": "IfNotPresent",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "infra": {
          "title": "Infrastructure Placement",
          "description": "Placement configuration for CDI infrastructure components.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nodeSelector": {
              "title": "Node Selector",
              "description": "Node selector for CDI infrastructure pods.",
              "type": "object",
              "default": {
                "kubernetes.io/os": "linux"
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "workload": {
          "title": "Workload Placement",
          "description": "Placement configuration for CDI workload components.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nodeSelector": {
              "title": "Node Selector",
              "description": "Node selector for CDI workload pods.",
              "type": "object",
              "default": {
                "kubernetes.io/os": "linux"
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "enabled": {
      "title": "Enabled",
      "description": "Whether this component is enabled. Controlled by the parent chart.",
      "type": "boolean"
    },
    "uploadProxy": {
      "title": "Upload Proxy",
      "description": "Expose CDI upload proxy externally for virtctl image-upload.",
      "type": "object",
      "properties": {
        "externalMode": {
          "title": "External Mode",
          "type": "object",
          "properties": {
            "enabled": {
              "title": "Enabled",
              "type": "boolean",
              "default": false
            },
            "hostname": {
              "title": "Hostname",
              "description": "FQDN for the upload proxy.",
              "type": "string",
              "default": ""
            },
            "ingressClassName": {
              "title": "Ingress Class",
              "type": "string",
              "default": ""
            },
            "certManager": {
              "title": "cert-manager",
              "type": "object",
              "properties": {
                "issuerRef": {
                  "title": "Issuer Reference",
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
